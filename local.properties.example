# Copy this file to local.properties on the release machine.
# Never commit local.properties, keystores, passwords, Play Console credentials,
# AdMob account IDs, or any other private release material.

# Upload key used to sign the Android App Bundle before Play App Signing.
# In Play Console, keep Play App Signing enabled and use the Google-generated
# app signing key unless there is a specific reason to manage that key directly.
JARPICK_RELEASE_STORE_FILE=C:/secure/path/jarpick-upload-key.jks
JARPICK_RELEASE_STORE_PASSWORD=replace-with-local-secret
JARPICK_RELEASE_KEY_ALIAS=jarpick-upload
JARPICK_RELEASE_KEY_PASSWORD=replace-with-local-secret

# Production AdMob configuration.
# ADMOB_APP_ID is the Android app ID, for example ca-app-pub-0000000000000000~0000000000.
# ADMOB_BANNER_ID is the banner ad unit ID, for example ca-app-pub-0000000000000000/0000000000.
ADMOB_APP_ID=ca-app-pub-your-production-publisher-id~your-production-app-id
ADMOB_BANNER_ID=ca-app-pub-your-production-publisher-id/your-production-banner-id
